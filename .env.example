# JARVIS secrets. Copy to ~/.jarvis/.env on the host (chmod 600).
# Loaded by systemd via EnvironmentFile=, available as process.env.*.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to JARVIS
TELEGRAM_ALLOWED_USER_IDS=

# Path to the OAuth credential file produced by `pi-ai`.
# CODEX_OAUTH_CREDS_PATH=  # optional override; defaults to <data_dir>/.codex-creds.json.

# Optional Anthropic API key (fallback provider)
ANTHROPIC_API_KEY=

# Speech-to-text uses local whisper.cpp configured in config.yaml; no OpenAI key is required.

# Exa API key — required, powers the `web_search` tool (search + page fetch).
# Get one at https://dashboard.exa.ai/api-keys
EXA_API_KEY=
