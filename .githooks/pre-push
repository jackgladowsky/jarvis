#!/bin/bash
# Pre-push hook — runs typecheck + lint + format check before pushing.
# Installed by setting core.hooksPath .githooks.

echo "🔍 Running typecheck + lint + format check before push..."

# Run typecheck (noEmit is fast)
if ! pnpm exec tsc --noEmit 2>/dev/null; then
  echo ""
  echo "❌ Typecheck failed. Fix issues before pushing."
  exit 1
fi

# Run linter
if ! pnpm run lint 2>/dev/null; then
  echo ""
  echo "❌ Lint failed. Fix issues before pushing."
  echo "   Run: pnpm run lint --fix"
  exit 1
fi

# Run format check
if ! pnpm run format:check 2>/dev/null; then
  echo ""
  echo "❌ Format check failed. Fix with: pnpm exec prettier --write ."
  exit 1
fi

echo "✅ Typecheck + lint + format passed"