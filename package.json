{
  "name": "jarvis",
  "version": "0.7.0",
  "private": false,
  "type": "module",
  "description": "Self-hosted Telegram AI assistant with host-local state, scheduler, and background workers.",
  "engines": {
    "node": ">=20.18.1"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm build && pnpm run test:version-gate && node scripts/run-tests.mjs",
    "coverage": "c8 --check-coverage --lines 60 --statements 60 --functions 55 --branches 65 --reporter=text --reporter=lcov pnpm test",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run coverage",
    "start": "node dist/index.js",
    "version:show": "pnpm run build && node dist/lib/version.js",
    "version:check-pr": "node scripts/check-pr-version.mjs",
    "test:version-gate": "node --test scripts/check-pr-version.test.mjs",
    "release:bump": "node scripts/bump-version.mjs",
    "release": "node skills/release/scripts/release.mjs",
    "deploy:self": "bash scripts/safe-deploy.sh --self-main",
    "workbench:smoke": "pnpm build && node dist/workbench/smoke.js",
    "pr:watch": "pnpm build && node dist/pr-ci/watch.js"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.61.1",
    "typebox": "^1.1.38",
    "undici": "7.28.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "7.6.3",
      "undici": "7.28.0",
      "ws": "8.21.0"
    }
  },
  "license": "MIT"
}
