{
  "name": "jarvis",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "description": "Self-hosted Telegram AI assistant with host-local state, scheduler, and background workers.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm build && find dist -name '*.test.js' | xargs node --test",
    "coverage": "c8 --reporter=text --reporter=lcov pnpm test",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run coverage",
    "start": "node dist/index.js",
    "version:show": "pnpm run build && node dist/lib/version.js",
    "release:bump": "node scripts/bump-version.mjs",
    "release": "node skills/release/scripts/release.mjs",
    "workbench:smoke": "pnpm build && node dist/workbench/smoke.js"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.0",
    "@mariozechner/pi-ai": "^0.73.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.61.1",
    "typebox": "^1.1.38",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0"
  },
  "license": "MIT"
}
