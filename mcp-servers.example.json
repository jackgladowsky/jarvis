{
  "servers": {
    "local-readonly": {
      "command": "npx",
      "args": ["-y", "@example/read-only-mcp-server"],
      "env": {
        "SERVICE_TOKEN": "$SERVICE_TOKEN"
      },
      "timeout_ms": 15000,
      "read_only": true
    },
    "executor-local": {
      "url": "http://127.0.0.1:4789/mcp",
      "timeout_ms": 15000,
      "read_only": true,
      "allow_localhost": true
    },
    "hosted-readonly": {
      "url": "https://mcp.example.net/mcp",
      "headers": {
        "Authorization": "Bearer $HOSTED_MCP_TOKEN"
      },
      "timeout_ms": 15000,
      "read_only": true
    }
  }
}
